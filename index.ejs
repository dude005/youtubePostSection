<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>MyTube</title>
<style>
body {
    margin:0;
    background:#0f0f0f;
    color:white;
    font-family:Arial, sans-serif;
}

.nav {
    background:#202020;
    padding:10px 20px;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.feed {
    max-width:700px;
    margin:20px auto;
}

.post {
    background:#1e1e1e;
    border-radius:10px;
    margin-bottom:20px;
    overflow:hidden;
}

.post-banner {
    width:100%;
    max-height:200px;
    object-fit:cover;
}

.post-header {
    display:flex;
    align-items:center;
    padding:10px;
    gap:10px;
}

.pfp {
    width:40px;
    height:40px;
    border-radius:50%;
}

.post-content {
    padding:10px;
}

button {
    padding:5px 10px;
    background:#3ea6ff;
    border:none;
    color:white;
    cursor:pointer;
    margin-right:5px;
}

.comment, .reply {
    background:#2a2a2a;
    padding:10px;
    margin:5px 0;
    border-radius:8px;
}

.comment-header {
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.comment-author {
    display:flex;
    align-items:center;
    gap:5px;
}

.comment-content {
    margin-top:5px;
}

.replies {
    margin-left:40px;
}

.poll-option {
    margin:10px 0;
}

.poll-bar-bg {
    background:#333;
    border-radius:20px;
    width:100%;
    height:20px;
    margin-top:5px;
}

.poll-bar {
    height:20px;
    background:#3ea6ff;
    border-radius:20px;
    display:flex;
    align-items:center;
    justify-content:center;
    color:white;
    font-size:12px;
}

textarea,input {
    width:100%;
    background:#222;
    color:white;
    border:none;
    padding:8px;
    margin:5px 0;
    border-radius:5px;
}
</style>
</head>
<body>

<div class="nav">
    <div>MyTube</div>
    <div><%= user.username %></div>
</div>

<div class="feed">

<!-- CREATE POST -->
<div class="post">
<form action="/create-post" method="POST" enctype="multipart/form-data">
    <textarea name="content" placeholder="What's on your mind?"></textarea>
    <input name="option1" placeholder="Poll option 1 (optional)">
    <input name="option2" placeholder="Poll option 2 (optional)">
    <input type="text" name="bannerImage" placeholder="Banner image URL (optional)">
    <button>Create</button>
</form>
</div>

<!-- POSTS -->
<% posts.forEach(p => { %>
<div class="post">

    <% if(p.banner){ %>
        <img src="<%= p.banner %>" class="post-banner">
    <% } %>

    <div class="post-header">
        <img src="<%= p.pfp %>" class="pfp">
        <strong><%= p.author %></strong>
        <span style="margin-left:auto; font-size:12px; color:#aaa;">
            <%= Math.floor((Date.now() - p.createdAt)/1000) %> sec ago
        </span>
    </div>

    <div class="post-content">
        <p><%= p.content %></p>

        <!-- LIKE / DISLIKE -->
        <div>
            <form action="/like-post/<%= p.id %>" method="POST" style="display:inline;">
                <button>👍 <%= p.likes.length %></button>
            </form>
            <form action="/dislike-post/<%= p.id %>" method="POST" style="display:inline;">
                <button>👎 <%= p.dislikes.length %></button>
            </form>
        </div>

        <!-- POLL -->
        <% if(p.poll){ %>
            <% Object.keys(p.poll.options).forEach(option => {
                const votes = p.poll.votes[option]?.length || 0;
                const totalVotes = p.poll.totalVotes || 1;
                const percent = Math.round((votes / totalVotes) * 100);
            %>
            <div class="poll-option">
                <form action="/poll/<%= p.id %>" method="POST" style="display:inline;">
                    <input type="hidden" name="option" value="<%= option %>">
                    <button><%= option %> - <%= votes %> votes</button>
                </form>
                <div class="poll-bar-bg">
                    <div class="poll-bar" style="--width-per: <%= percent %>%;"></div>

<style>
  .poll-bar {
    /* Use the variable with a fallback */
    width: var(--width-per, 0%);
  }
</style>
                </div>
            </div>
            <% }) %>
        <% } %>

        <!-- COMMENTS -->
        <div>
        <% p.comments.forEach(c => { %>
            <div class="comment">
                <div class="comment-header">
                    <div class="comment-author">
                        <img src="<%= c.pfp %>" class="pfp">
                        <strong><%= c.author %></strong>
                    </div>
                    <span style="font-size:12px; color:#aaa;">
                        <%= Math.floor((Date.now() - c.createdAt)/1000) %> sec ago
                    </span>
                </div>

                <div class="comment-content">
                    <p><%= c.text %></p>
                </div>

                <!-- COMMENT ACTIONS -->
                <div>
                    <form action="/like-comment/<%= p.id %>/<%= c.id %>" method="POST" style="display:inline;">
                        <button>👍 <%= c.likes.length %></button>
                    </form>
                    <form action="/dislike-comment/<%= p.id %>/<%= c.id %>" method="POST" style="display:inline;">
                        <button>👎 <%= c.dislikes.length %></button>
                    </form>
                    <form action="/delete-comment/<%= p.id %>/<%= c.id %>" method="POST" style="display:inline;">
                        <button>🗑 Delete</button>
                    </form>
                </div>

                <!-- REPLIES -->
                <div class="replies">
                <% c.replies.forEach(r => { %>
                    <div class="reply">
                        <div class="comment-header">
                            <div class="comment-author">
                                <img src="<%= r.pfp %>" class="pfp">
                                <strong><%= r.author %></strong>
                            </div>
                            <span style="font-size:12px; color:#aaa;">
                                <%= Math.floor((Date.now() - r.createdAt)/1000) %> sec ago
                            </span>
                        </div>
                        <div class="comment-content">
                            <p><%= r.text %></p>
                        </div>
                    </div>
                <% }) %>

                <form action="/reply/<%= p.id %>/<%= c.id %>" method="POST">
                    <input name="text" placeholder="Reply">
                    <button>Reply</button>
                </form>
                </div>

            </div>
        <% }) %>

        <!-- ADD COMMENT FORM -->
        <form action="/comment/<%= p.id %>" method="POST">
            <input name="text" placeholder="Add a comment">
            <button>Comment</button>
        </form>
        </div>

    </div>
</div>
<% }) %>

</div>
</body>
</html>